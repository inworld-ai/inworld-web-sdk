{
  "env": {
    "es2021": true
  },
  "extends": [
    "plugin:markdown/recommended",
    "plugin:prettier/recommended",
    "prettier/prettier",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint",
    "simple-import-sort"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      { 
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ],
    "simple-import-sort/imports": "error",
    "simple-import-sort/exports": "error",
    "no-throw-literal": "off",
    "max-lines": ["error", 1000]
  },
  "overrides": [
    {
      "files": [
        "examples/**/*.ts",
        "examples/**/*.tsx"
      ],
      "rules": {
        "no-console": "off"   
      }
    },
    {
      "files": [
        "**/__tests__/**/*.ts"
       ],
      "rules": {
        "max-lines": "off"   
      }
    }
  ],
  "ignorePatterns": ["proto", "build"]
}
